# Swimfit Cloud Functions — environment reference.
#
# This file is documentation, not live configuration: every secret listed
# below is a Firebase Secret Manager secret (defineSecret in index.js), which
# Cloud Functions injects at runtime from Secret Manager — NOT from a .env
# file. Set each one with:
#
#   firebase functions:secrets:set PADDLE_WEBHOOK_SECRET
#   firebase functions:secrets:set PADDLE_API_KEY
#   firebase functions:secrets:set SMTP_HOST
#   firebase functions:secrets:set SMTP_PORT
#   firebase functions:secrets:set SMTP_USER
#   firebase functions:secrets:set SMTP_PASS
#   firebase functions:secrets:set ANTHROPIC_API_KEY
#
# (each prompts for the value interactively — nothing is echoed, and nothing
# belongs in a committed file.)
#
# PADDLE_ENVIRONMENT below is the one real, non-secret exception — a
# defineString param, not a secret — so it CAN be set via an actual
# functions/.env or functions/.env.<project-id> file if you want to override
# the 'production' default (e.g. for a local/dev deploy against a Paddle
# sandbox account). Copy this file to .env.<your-project-id> and edit the
# value if you need that; do not add real secrets to it.

# --- Paddle Billing ---------------------------------------------------------
# The webhook SIGNING SECRET for the notification destination registered in
# Paddle Developer Tools -> Notifications -> Webhook destinations (pointed at
# the deployed paddleWebhook URL). Verifies a delivery really came from
# Paddle. Different credential from PADDLE_API_KEY below — never conflate them.
PADDLE_WEBHOOK_SECRET=

# A real Paddle API key (Paddle Dashboard -> Developer Tools -> Authentication),
# used by the Paddle Node SDK to make authenticated calls back to Paddle —
# currently just paddleCustomerPortalSession's customerPortalSessions.create().
PADDLE_API_KEY=

# Non-secret. 'production' (default, used when unset) or 'sandbox'.
PADDLE_ENVIRONMENT=production

# --- Welcome email (onUserCreated) ------------------------------------------
# Optional — skipped harmlessly if unset. Powers the branded welcome email
# sent on every new signup, regardless of which auth method created it.
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# --- AI Swim Coach -----------------------------------------------------------
# Required for the aiSwimCoach function. Get a key from https://console.anthropic.com
ANTHROPIC_API_KEY=
