rules_version = '2';

// Swimfit Firestore rules.
//
// users/{uid}       — a swimmer's own profile, including the onboarding wizard fields
//                      (fullName, country, age, dob, username, onboardingComplete, plus the
//                      training-specialization/fitness-metrics fields collected in Steps 2-3:
//                      disciplines, distance, goal, pb50, pb100, workingWeight, strengthLimit).
//                      Only that swimmer can ever read or write it — 100% private.
// usernames/{name}  — a permanent uid reservation keyed by the (lowercase,
//                      normalized) username itself. Its mere existence is the
//                      single source of truth for "is this username taken".
//                      create-only/immutable, so no client can ever hijack or
//                      free up a username someone else already claimed — this
//                      is what makes usernames actually unique, not just
//                      "unique at the moment nobody's watching".
// stats/counters    — the public "registered swimmers" counter. Readable by anyone
//                      (including signed-out visitors, since it's shown on the marketing
//                      site's Hero), but never writable from a client — it's only ever
//                      incremented by the onUserCreated Cloud Function via the Admin SDK,
//                      which bypasses these rules entirely.
// paddle_subscriptions/{docId} — billing records. A swimmer can read only their own
//                      (matched by the firebaseUid the checkout attached), never write.
// swim_logs/{uid}/entries/{entryId} — a swimmer's manually-logged distance entries for
//                      the Distance Tracker page. Owner-only; deletable (to fix a mislog)
//                      but never editable in place — delete and re-log instead. An optional
//                      durationSeconds field feeds the Tracker's average-pace chart.
// personal_bests/{uid}/entries/{entryId} — a swimmer's manually-logged PB times, for the
//                      Tracker's PB progression chart. Same owner-only, create+delete,
//                      no-edit-in-place shape as swim_logs.
// coach_history/{uid} — persisted AI Coach chat transcript for the full-screen page. Available
//                      to any signed-in, non-suspended swimmer — there is no paywall/tier gate
//                      anywhere in this app anymore (see aiSwimCoach in functions/index.js).
//                      Text only — image attachments are never persisted here, only a
//                      placeholder, to stay well under the 1 MiB document size limit and to
//                      avoid ever storing image bytes twice.
// coach_widget_history/{uid} — identical shape/rules, but for the floating AI Coach widget's
//                      own transcript, kept in a separate doc so it never collides with the
//                      full-screen page's saved conversation above.
// admin_chats/{uid}   — Admin Panel direct-message thread metadata (lastMessageText,
//                      unreadForUser, etc) plus the /messages subcollection itself. Real-time
//                      on both sides: the owning swimmer reads/writes their own thread (sender
//                      must be 'user'), and the admin (matched directly on the verified ID
//                      token's email claim via isAdminAuth() — no Cloud Function round-trip,
//                      so both sides get instant onSnapshot delivery) can read every thread and
//                      write messages with sender 'admin' plus the metadata doc. This is the one
//                      deliberate exception to "privileged cross-user ops go through a Cloud
//                      Function" (see functions/index.js) — a live chat can't be real-time
//                      through a request/response endpoint, and the admin identity check here
//                      is exactly as strong as isAdminEmail() server-side, just expressed in
//                      rules syntax against the same hardcoded address.
service cloud.firestore {
  function isAdminAuth() {
    return request.auth != null && request.auth.token.email == 'swimfit.ae@gmail.com';
  }

  // Shared field-level validation for users/{uid} writes. Keeping this in one
  // function (rather than duplicating it across the create/update rules)
  // means the onboarding fields can only ever be tightened in one place.
  function isValidProfileWrite(data) {
    return (!('username' in data) || (data.username is string && data.username.matches('^[a-z0-9_]{3,20}$')))
      && (!('age' in data) || (data.age is int && data.age >= 5 && data.age <= 120))
      && (!('dob' in data) || (data.dob is string && data.dob.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$')))
      && (!('fullName' in data) || (data.fullName is string && data.fullName.size() > 0 && data.fullName.size() <= 80))
      && (!('country' in data) || (data.country is string && data.country.size() > 0 && data.country.size() <= 60))
      && (!('onboardingComplete' in data) || data.onboardingComplete is bool)
      && (!('trialStartedAt' in data) || data.trialStartedAt is timestamp)
      && (!('disciplines' in data) || (data.disciplines is list && data.disciplines.size() >= 1 && data.disciplines.size() <= 5))
      && (!('distance' in data) || (data.distance is number && data.distance >= 500 && data.distance <= 10000))
      && (!('goal' in data) || (data.goal is string && data.goal.matches('^(endurance|speed|technique)$')))
      && (!('pb50' in data) || (data.pb50 is string && data.pb50.size() <= 10))
      && (!('pb100' in data) || (data.pb100 is string && data.pb100.size() <= 10))
      && (!('workingWeight' in data) || (data.workingWeight is string && data.workingWeight.size() <= 20))
      && (!('strengthLimit' in data) || (data.strengthLimit is string && data.strengthLimit.size() <= 20));
  }

  match /databases/{database}/documents {
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      // Field-level allowlist, not just an owner-check: even though this is
      // the swimmer's own doc, restricting *which* fields the client can
      // ever write means adding a privileged field here later (e.g. an
      // entitlement flag) can't accidentally become client-settable just
      // because it lives in a doc the owner already has write access to.
      // create/update are split because resource.data doesn't exist yet on
      // the first write, so .diff() can't run against it.
      allow create: if request.auth != null && request.auth.uid == uid
        && request.resource.data.keys()
             .hasOnly(['email', 'displayName', 'photoURL', 'provider', 'createdAt', 'lastLoginAt',
                       'fullName', 'country', 'age', 'dob', 'username', 'onboardingComplete', 'trialStartedAt',
                       'disciplines', 'distance', 'goal', 'pb50', 'pb100', 'workingWeight', 'strengthLimit'])
        && isValidProfileWrite(request.resource.data);
      allow update: if request.auth != null && request.auth.uid == uid
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['email', 'displayName', 'photoURL', 'provider', 'createdAt', 'lastLoginAt',
                       'fullName', 'country', 'age', 'dob', 'username', 'onboardingComplete', 'trialStartedAt',
                       'disciplines', 'distance', 'goal', 'pb50', 'pb100', 'workingWeight', 'strengthLimit'])
        && isValidProfileWrite(request.resource.data);
      allow delete: if false;
    }

    match /swim_logs/{uid}/entries/{entryId} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null && request.auth.uid == uid
        && request.resource.data.keys().hasOnly(['distanceMeters', 'loggedAt', 'discipline', 'durationSeconds', 'createdAt'])
        && request.resource.data.distanceMeters is number
        && request.resource.data.distanceMeters > 0 && request.resource.data.distanceMeters <= 100000
        && request.resource.data.loggedAt is timestamp
        && (!('discipline' in request.resource.data)
            || (request.resource.data.discipline is string && request.resource.data.discipline.size() <= 40))
        && (!('durationSeconds' in request.resource.data)
            || (request.resource.data.durationSeconds is number
                && request.resource.data.durationSeconds > 0 && request.resource.data.durationSeconds <= 36000));
      allow update: if false;
      allow delete: if request.auth != null && request.auth.uid == uid;
    }

    // A swimmer's manually-logged Personal Best times, for the Distance
    // Tracker's PB progression chart — owner-only, create+delete (no
    // in-place edit, same "fix a mislog by deleting and re-logging"
    // pattern as swim_logs above).
    match /personal_bests/{uid}/entries/{entryId} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null && request.auth.uid == uid
        && request.resource.data.keys().hasOnly(['discipline', 'distanceLabel', 'timeSeconds', 'loggedAt', 'createdAt'])
        && request.resource.data.discipline is string && request.resource.data.discipline.size() <= 40
        && request.resource.data.distanceLabel is string && request.resource.data.distanceLabel.size() <= 10
        && request.resource.data.timeSeconds is number
        && request.resource.data.timeSeconds > 0 && request.resource.data.timeSeconds <= 36000
        && request.resource.data.loggedAt is timestamp;
      allow update: if false;
      allow delete: if request.auth != null && request.auth.uid == uid;
    }

    match /coach_history/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null && request.auth.uid == uid
        && request.resource.data.keys().hasOnly(['messages', 'updatedAt'])
        && request.resource.data.messages is list && request.resource.data.messages.size() <= 60;
    }

    // Same shape as coach_history, but for the floating AI Coach widget's
    // own transcript — kept in a separate document so the widget and the
    // full-screen page never overwrite each other's saved conversation.
    match /coach_widget_history/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null && request.auth.uid == uid
        && request.resource.data.keys().hasOnly(['messages', 'updatedAt'])
        && request.resource.data.messages is list && request.resource.data.messages.size() <= 60;
    }

    match /admin_chats/{uid} {
      allow get: if request.auth != null && (request.auth.uid == uid || isAdminAuth());
      // list is admin-only — a swimmer never lists across admin_chats (they
      // only ever get() their own doc by uid), so this can't be used to
      // enumerate other threads; it's what lets the Admin Panel run one
      // live onSnapshot(collection('admin_chats')) for real-time unread
      // badges across every swimmer instead of re-fetching per thread.
      allow list: if isAdminAuth();
      allow write: if isAdminAuth()
        && request.resource.data.keys().hasOnly(['lastMessageText', 'lastMessageAt', 'lastSender', 'unreadForUser', 'unreadForAdmin'])
        && (!('lastMessageText' in request.resource.data) || (request.resource.data.lastMessageText is string && request.resource.data.lastMessageText.size() <= 2000));

      match /messages/{messageId} {
        allow read: if request.auth != null && (request.auth.uid == uid || isAdminAuth());
        allow create: if request.resource.data.keys().hasOnly(['sender', 'text', 'createdAt'])
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0 && request.resource.data.text.size() <= 2000
          && ((request.auth != null && request.auth.uid == uid && request.resource.data.sender == 'user')
              || (isAdminAuth() && request.resource.data.sender == 'admin'));
        allow update, delete: if false;
      }
    }

    match /usernames/{username} {
      // A single-document get (used for the live "is this available?" check,
      // now surfaced in the upfront Create Account form before the swimmer
      // has even verified their email — so before request.auth exists — and
      // again inside the claiming transaction) is allowed for anyone. list is
      // blocked so the full username directory can never be scraped/enumerated,
      // and a get only ever reveals "does this exact username exist", never
      // who it belongs to beyond the uid already on the doc.
      allow get: if true;
      allow list: if false;
      // Only ever a brand-new reservation the caller is making for themselves,
      // for a well-formed username, holding nothing but the two expected
      // fields. Firestore only evaluates "create" when the document doesn't
      // already exist, so once *any* uid has claimed a given username this
      // branch can never fire again for that document — that's the actual
      // uniqueness guarantee, not just an application-level check.
      allow create: if request.auth != null
        && username.matches('^[a-z0-9_]{3,20}$')
        && request.resource.data.keys().hasOnly(['uid', 'createdAt'])
        && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    match /stats/counters {
      allow get: if true;
      allow list, create, update, delete: if false;
    }

    match /paddle_subscriptions/{docId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.firebaseUid;
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
